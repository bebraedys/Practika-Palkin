<Window x:Class="palkinprog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:palkinprog"
        mc:Ignorable="d"
        Title="Мастер Пол - Управление партнерами" 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Стили для кнопок -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стили для заголовков -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </Window.InputBindings>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#F3F3F3" Padding="16" CornerRadius="8" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Управление партнерами" FontSize="24" FontWeight="Bold" Foreground="#333"/>
                <TextBlock Text="Подсистема работы с партнерами компании «Мастер пол»" 
                           FontSize="14" Foreground="#666" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Панель инструментов -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="+ Добавить партнера" Style="{StaticResource PrimaryButtonStyle}" 
                    Click="AddPartnerClick"/>
            <Button Content="🔄 Обновить" Style="{StaticResource PrimaryButtonStyle}" 
                    Click="RefreshClick"/>
        </StackPanel>

        <!-- Таблица партнеров -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
            <DataGrid x:Name="PartnersDataGrid" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="White"
                      AlternatingRowBackground="#F9F9F9"
                      RowHeight="40"
                      MouseDoubleClick="PartnersDataGridMouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="200"/>
                    <DataGridTextColumn Header="Тип партнера" Binding="{Binding PartnerTypeName}" Width="150"/>
                    <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating}" Width="70"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                    <DataGridTextColumn Header="Общие продажи (₽)" Binding="{Binding TotalSalesAmount, StringFormat={}{0:N2}}" Width="120"/>
                    <DataGridTextColumn Header="Скидка" Binding="{Binding DiscountDescription}" Width="130"/>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Редактировать" Click="EditPartnerClick"/>
                        <MenuItem Header="Продажи" Click="ShowSalesHistoryClick"/>
                        <Separator/>
                        <MenuItem Header="Удалить" Click="DeletePartnerClick"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Border>

        <!-- Статус бар -->
        <Border Grid.Row="3" Background="#F3F3F3" Padding="12,8" CornerRadius="4" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0" Text="Готово" Foreground="#666"/>
                <TextBlock Grid.Column="1" Text="F5 - Обновить | Двойной клик - Редактировать" Foreground="#999" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
